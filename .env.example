# ============================================================================
# ContextPilot AI — Environment Configuration
# Copy this file to `.env` and fill in real values before deploying.
# All secrets below are DUMMY PLACEHOLDERS — replace them with your own keys.
# ============================================================================

# --- App -------------------------------------------------------------------
APP_ENV=development
APP_NAME=ContextPilot AI
API_V1_PREFIX=/api/v1
SECRET_KEY=REPLACE_WITH_A_RANDOM_64_CHAR_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# --- LLM Providers (dummy keys — swap in real ones at deploy time) --------
LLM_PROVIDER=openai                 # openai | anthropic | local
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_API_KEY
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-sonnet-5

# --- Vector Store ------------------------------------------------------
VECTOR_STORE_PROVIDER=faiss          # faiss | pinecone | weaviate
VECTOR_STORE_DIR=./data/vector_store

PINECONE_API_KEY=REPLACE_WITH_YOUR_PINECONE_API_KEY
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=contextpilot-kb

WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=REPLACE_WITH_YOUR_WEAVIATE_API_KEY

# --- Database ----------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://contextpilot:contextpilot@postgres:5432/contextpilot
POSTGRES_USER=contextpilot
POSTGRES_PASSWORD=contextpilot
POSTGRES_DB=contextpilot

# --- Cache / Queue -------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Observability -------------------------------------------------------
LANGSMITH_API_KEY=REPLACE_WITH_YOUR_LANGSMITH_API_KEY
LANGSMITH_PROJECT=contextpilot-ai
LANGCHAIN_TRACING_V2=false

# --- Evaluation / Confidence Thresholds ---------------------------------
CONFIDENCE_ESCALATION_THRESHOLD=0.62
CONFIDENCE_AUTO_ANSWER_THRESHOLD=0.80

# --- Frontend --------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
